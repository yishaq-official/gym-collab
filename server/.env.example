APP_NAME="dbugym API"
APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=Africa/Addis_Ababa
APP_URL=http://localhost:8000

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dbugym
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

AUTH_TOKEN_TTL=604800
AUTH_TOKEN_ISSUER=dbugym-api
AUTH_TOKEN_SECRET=change-me-in-production
AUTH_PASSWORD_MIN_LENGTH=8

FRONTEND_URL=http://localhost:5173
UPLOADS_AVATARS_DIR=storage/uploads/avatars
UPLOADS_LOGOS_DIR=storage/uploads/logos
CSV_DELIMITER=,
CSV_ENCLOSURE="

CHAPA_ENABLED=true
CHAPA_BASE_URL=https://api.chapa.co
CHAPA_SECRET_KEY=
CHAPA_PUBLIC_KEY=
CHAPA_CURRENCY=ETB
CHAPA_TIMEOUT_SECONDS=30
